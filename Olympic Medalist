// This function asks the user for the names of two ski jump competitors
// and the distance each competitor jumped. It compares the distances
// and returns the name of the competitor who jumped farther.
// If both competitors jump the same distance, it returns "TIE".
string distanceMedalist() {
    string name1,name2;
    double distance1, distance2;

    cout << "------ Ski Jump Distance -----" << endl; // made this so I know what function I am on
     cout << "What is the name of your first competer?: " << endl;
    cin >> name1;
    cout << "How far did they go?: " << endl;
    cin >> distance1;

    cout << "What is the name of your second competeor?: " << endl;
    cin >> name2;
    cout << "How far did they go?: " << endl;
    cin >> distance2;
// if statments reutrn the name from below and decides who won and who lost
    if (distance1 > distance2) {
        return name1;

    } else if (distance1 < distance2) {
        return name2;
    } else if (distance1 == distance2) {
        return "TIE";
    }
} // end of function distanceMedalist




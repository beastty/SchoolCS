#include <iostream>
using namespace std;

// TIP To <b>Run</b> code, press <shortcut actionId="Run"/> or click the <icon src="AllIcons.Actions.Execute"/> icon in the gutter.
int main() {
int sum = 0;
float ave;
int min = 0;
int max = 0;

    int code[10];

    //cout << "Please enter 10 numbers:";


    for (int i = 0; i < 10; i++) {

        cout << "Enter Number " << i+1 <<": ";
        cin >> code[i];
    }

    cout << "Data Values: " << endl;
    for (int i =0; i <10; i++) {
        cout << "Index " << i << ": " << code[i] << endl;
    }

    cout << "Array Calculation" << endl;


    for (int i=0; i<10; i++) {
        sum += code[i];

    }

    cout << "Total: " << sum << endl;

    ave = (float)sum/10;
    cout << "Average: " << ave << endl;

    min = code[0];
    for (int i=1; i<10; i++) {
        if (code[i] < min) {
            min = code[i];


        } else if (code[i] > max) {
            max = code[i];
        }

    }
    cout << "Your minimum value is: " << min << endl;
    cout << "Your maximum value is: " << max << endl;
    return 0;

}

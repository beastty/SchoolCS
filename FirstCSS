// This function asks the user to pick a number
// If the number is dvidible by 3 and 5 it will output FizzBuzz
// if its just divisible by 3 it will output fizz
// if its just divisible by 5 is will output buzz all to console
void fuzz() {
    // start of function fuzz
    //  initalize the int var and make it equal to num then set the user input to what the var is
    int num;
    cout << "Please pick a number: " << endl;
    cin >> num;

    for (int i = 1; i <= num; i++) {
        // checks if its a multiple of 3 and 5 at the same time then if it does console says FizzBuzz
        if (i % 3 == 0 && i % 5 == 0) {
            cout << "FizzBuzz";
            // checks if its a multiple of 3 then if it is it says "Fizz" to console
        } else if (i % 3 == 0) {
            cout << "Fizz";
            // checks if its a multiple of 5 then if it is it says "Buzz" to console
        } else if (i % 5 == 0) {
            cout << "Buzz";
            // if its none is just excustes a space to console
        } else {
            cout << i << " ";
        }
    }
} // end of function "fuzz"


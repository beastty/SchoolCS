// This function asks the users for there first and second number
// Then is compares the numbers and decides is one is bigger or
// one is smaller or if they tied and then return saying which is bigger or equal
// Then outputs it into console
// Start of the  number function.
void number() {
    int a, b;
    // asks the users for their first number and second number then it sets the int a / b var to the number the user sets
    cout << "Please enter your first number: " << endl;
    cin >> a;
    cout << "Please enter your second number: " << endl;
    cin >> b;


    bool isEqual = (a == b);
    bool isSmaller = (a < b);

    if (isEqual) {
        // if the 2 numbers are equal
        cout << "The numbers are equal to each other!" << endl;
    } else if (isSmaller) {
        // if the first number is smaller then the second number
        cout << "Your first number is smaller!" << endl;
    } else {
        // if the first number is larger then the second number
        cout << "The first number is larger!" << endl;
    }
} // end of function number
// This function asks a user to input a triangular number then makes a triangle with
// "*" then outputs in console
void triangle() {
    // start of function triangle
    int count;
    // asks the user how many triangler numbers they want then the input is what the console sets it to
    cout << "Enter how many triangular numbers: ";
    cin >> count;

    // init var
    int n = 1;
    // make a while loop while the count var the user inputs is greater then one
    while (n <= count) {
        // formula for triangle numbers
        int triangleNum = n * (n + 1) / 2;

        // tell the user how many triagnele there is
        cout << "\nTriangle #" << n << " is: " << triangleNum << endl;


        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= i; j++) {
                cout << "* ";
            }
            cout << endl;
        }
        n++;
    }
} // end of function triangle

// This function asks the user to input 10 diffrent numbers into console
// When the forloop hits 10 it will calctualute the average the sum
// THen it will export the sum anverage number to console for the user to see
void sum() {
    // start of function sum
    int num;
    int sum = 0;
    float ave;

    cout << "Enter your first numbers: ";
    // its a for loop to make it so until the user has entered 10 numbers i will go up until its 10

    for (int i = 0; i < 10; i++) {
        cin >> num; // sets the num var to what the user says
        sum += num; // sets the sum is equal to the addition of the numbers

        ave = sum / 10.00; // formula to find average
    }
    cout << "The sum of all your numbers is: " << sum << endl; // get the sum of all the numbers
    cout << "The average number is: " << ave << endl; // get the average of the numbers
} // end of function sum


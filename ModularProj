void random(int code[3]) {

    srand(time(0));
    code[0] = rand() % 10;
    code[1] = rand() % 10;
    while (code[1] == code[0]) {
        code[1] = rand() % 10;
    }
    code[2] = rand() % 10;
    while (code[2] == code[0] || code[2] == code[1]) {
        code[2] = rand() % 10;
    }

}



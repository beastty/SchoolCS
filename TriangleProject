bool isTriangle(int x, int y, int z) {
//  int x, y, z;

    if (x + y + z == 180 && x > 0 && y > 0 && z > 0) {
        return true;
    } else {
        return false;
    }
}


void triangleType(int x, int y, int z) {
    bool isTri = isTriangle(x,y,z);
    if (isTri) {

        if (x == y && y == z && x + y + z == 180) {
            cout << "You have a Equilateral triangle" << endl;

        } else if (x != + y != + z == 180) {
            cout << "You have a Scalene triangle" << endl;
        } else if (x == y || y == z && x + y + z == 180) {
            cout << "You have a Isosceles triangle" << endl;
        }
    } else {
        cout << "You do not have a proper triangle" << endl;
    }

    }
